#!/bin/bash

echo "🚀 Validando código antes do push..."
echo ""

# Verifica lint
echo "🔍 Executando dart analyze..."
ANALYZE_OUTPUT=$(dart analyze 2>&1)
ANALYZE_EXIT_CODE=$?

if [ $ANALYZE_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ PUSH REJEITADO!"
    echo ""
    echo "🚨 Problemas de lint encontrados:"
    echo ""
    echo "$ANALYZE_OUTPUT"
    echo ""
    echo "📋 Corrija todos os problemas antes de fazer push."
    echo ""
    exit 1
fi

# Verifica se há warnings/erros não relacionados a avoid_print em tools
if [ -n "$ANALYZE_OUTPUT" ]; then
    if echo "$ANALYZE_OUTPUT" | grep -v "tool/" | grep -q "info\|warning\|error"; then
        echo ""
        echo "❌ PUSH REJEITADO!"
        echo ""
        echo "🚨 Problemas de lint encontrados:"
        echo ""
        echo "$ANALYZE_OUTPUT"
        echo ""
        echo "📋 Corrija todos os problemas antes de fazer push."
        echo ""
        exit 1
    fi
fi

echo "✅ Análise de código passou!"

# Executa testes
echo "🧪 Executando testes..."
TEST_OUTPUT=$(dart test 2>&1)
TEST_EXIT_CODE=$?

if [ $TEST_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ PUSH REJEITADO!"
    echo ""
    echo "🚨 Testes falharam:"
    echo ""
    echo "$TEST_OUTPUT"
    echo ""
    echo "📋 Corrija os testes antes de fazer push."
    echo ""
    exit 1
fi

echo "✅ Testes passaram!"
echo ""
echo "🎉 Validação completa - push autorizado!"
echo ""

exit 0 